# WebSocket URL for Receving Room Audio (used by both frontend and backend)
OUTPUT_WEBSOCKET_URL=wss://ngrok-domain

# OpenAI API key for Realtime API (required for text and audio modes)
OPENAI_API_KEY=your-openai-api-key

# Digiself API key for authentication (used for both HTTP API and WebSocket x-api-key header)
DIGISELF_API_KEY=your-digiself-api-key

# Audio file URL for file mode (optional)
AUDIO_FILE_URL=
